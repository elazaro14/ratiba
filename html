<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TT-PRO Enterprise | Professional Timetable System</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root {
            --primary:#0f172a; --secondary:#1e293b; --accent:#22c55e;
            --sidebar-gradient: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
            --bg:#f8fafc; --border:#e2e8f0; --text:#334155; --danger:#ef4444; --warning:#f59e0b; --whatsapp:#25d366; --pdf:#e11d48;
        }
        body { margin:0; font-family:'Inter', system-ui, sans-serif; display:flex; height: 100vh; background:var(--bg); overflow:hidden; }

        /* SIDEBAR */
        .sidebar { width:340px; background: var(--sidebar-gradient); color:white; padding:20px; display: flex; flex-direction: column; gap: 10px; overflow-y: auto; box-shadow: 4px 0 15px rgba(0,0,0,0.3); z-index:10; border-right: 1px solid #334155; }
        .sidebar h2 { color: var(--accent); font-size: 1.1rem; text-align: center; border-bottom: 1px solid #334155; padding-bottom: 15px; margin:0; letter-spacing: 1px; }

        .setting-card { background: rgba(30, 41, 59, 0.5); padding: 12px; border-radius: 8px; border: 1px solid #334155; }
        .setting-card label { display: block; font-size: 10px; text-transform: uppercase; color: #94a3b8; margin-bottom: 4px; font-weight: 700; }
        .setting-card input, .setting-card select { width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #334155; background: #0f172a; color: white; font-size: 13px; box-sizing: border-box; margin-bottom: 5px; }

        .nav-label { font-size: 11px; color: #38bdf8; font-weight: 800; margin-top: 10px; border-left: 3px solid var(--accent); padding-left: 8px; text-transform: uppercase; letter-spacing: 0.5px; }

        .btn { width: 100%; padding: 12px; border-radius: 6px; border: none; cursor: pointer; font-weight: 700; font-size: 12px; transition: 0.2s; display: flex; align-items: center; gap: 8px; justify-content: center; }
        .btn-gen { background: var(--accent); color: #064e3b; box-shadow: 0 4px 0 #15803d; }
        .btn-gen:active { transform: translateY(2px); box-shadow: 0 2px 0 #15803d; }
        .btn-sec { background: #475569; color: white; }
        .btn-wa { background: var(--whatsapp); color: white; padding: 8px 15px; font-size: 11px; }
        .btn-pdf { background: var(--pdf); color: white; }

        /* MAIN */
        .main { flex:1; display: flex; flex-direction: column; overflow: hidden; }
        .top-bar { background: white; padding: 10px 25px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .tab-group { display: flex; gap: 5px; }
        .tab-group button { padding: 8px 15px; border: 1px solid var(--border); background: white; cursor: pointer; font-size: 12px; border-radius: 4px; font-weight: 600; }
        .tab-group button.active { background: var(--primary); color: white; border-color: var(--primary); }

        .content { flex:1; padding: 20px; overflow-y: auto; }
        #printableArea { background: white; padding: 20px; border-radius: 8px; }
        .table-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 15px; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }

        table { width: 100%; border-collapse: collapse; border: 2px solid #000; table-layout: fixed; }
        th, td { border: 1px solid #000; padding: 4px; text-align: center; font-size: 9px; height: 45px; }
        th { background: #f1f5f9; font-weight: 800; }

        .slot { padding: 4px; border-radius: 4px; font-weight: 700; background: #dcfce7; border: 1px solid #22c55e; line-height: 1.1; overflow: hidden; }
        .break-cell { background: #cbd5e1; font-weight: bold; width: 35px; writing-mode: vertical-rl; text-orientation: mixed; font-size: 10px; border: 2px solid #000 !important; }

        #header { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 20px; }
        #logoImg { height: 70px; width: auto; object-fit: contain; display: none; }

        @media print { 
            .sidebar, .top-bar { display: none !important; } 
            body { height: auto; overflow: visible; background: white; }
            .main, .content { overflow: visible; padding: 0; }
            .table-card { page-break-after: always; border: none; box-shadow: none; }
        }
    </style>
</head>
<body>

<div class="sidebar no-print">
    <h2>TT-PRO ENTERPRISE</h2>
    
    <div class="setting-card">
        <label>School Name</label>
        <input type="text" id="schName" value="TANZANIA SECONDARY SCHOOL" oninput="renderActiveView()">
        <label>Academic Year</label>
        <input type="text" id="acadYear" value="2026" oninput="renderActiveView()">
        <label>School Logo</label>
        <input type="file" id="logoUpload" accept="image/*" onchange="handleLogo(event)">
    </div>

    <div class="nav-label">Interval Settings</div>
    <div class="setting-card">
        <div style="display:flex; gap:5px;">
            <div style="flex:1"><label>Periods</label>
                <select id="totalPeriods">
                    <option value="8">8</option>
                    <option value="9" selected>9</option>
                    <option value="10">10</option>
                </select>
            </div>
            <div style="flex:1"><label>Dur (min)</label><input type="number" id="dur" value="40"></div>
        </div>
        <label>Start Time</label><input type="time" id="startTime" value="08:00">
        
        <div style="margin-top:8px; border-top:1px solid #334155; padding-top:8px;">
            <label style="color:#22c55e">Short Break (After P:)</label>
            <div style="display:flex; gap:5px;">
                <input type="number" id="breakAfter" value="2" style="flex:1">
                <input type="number" id="breakDur" value="20" style="flex:1">
            </div>
        </div>
        <div style="margin-top:8px; border-top:1px solid #334155; padding-top:8px;">
            <label style="color:#22c55e">Lunch (After P:)</label>
            <div style="display:flex; gap:5px;">
                <input type="number" id="lunchAfter" value="4" style="flex:1">
                <input type="number" id="lunchDur" value="45" style="flex:1">
            </div>
        </div>
    </div>

    <div class="nav-label">Core Actions</div>
    <button class="btn btn-gen" onclick="generate()">⚡ SHUFFLE & GENERATE</button>
    <button class="btn btn-pdf" onclick="exportPDF()">📄 EXPORT MASTER PDF</button>
    <button class="btn btn-sec" onclick="document.getElementById('csvIn').click()">📥 IMPORT CSV</button>
    <input type="file" id="csvIn" style="display:none" accept=".csv" onchange="handleCSV(event)">
</div>

<div class="main">
    <div class="top-bar">
        <div class="tab-group">
            <button id="tab-GENERAL" class="active" onclick="setView('GENERAL')">Master</button>
            <button id="tab-STREAM" onclick="setView('STREAM')">Stream</button>
            <button id="tab-TEACHER" onclick="setView('TEACHER')">Teacher</button>
            <button id="tab-LOADS" onclick="setView('LOADS')">Workload</button>
        </div>
        
        <div style="display: flex; gap: 10px; align-items: center;">
            <select id="viewFilter" onchange="renderActiveView()" style="padding: 5px; font-size: 11px; display:none; min-width: 150px;"></select>
            <button id="waBtn" class="btn btn-wa" style="display:none" onclick="shareWA()">📲 WHATSAPP SHARE</button>
        </div>
    </div>

    <div class="content">
        <div id="printableArea">
            <div id="header">
                <img id="logoImg" src="">
                <div style="text-align:center">
                    <h1 id="headerTitle" style="margin:0; font-size: 24px;"></h1>
                    <h4 id="headerYear" style="margin:5px 0 0 0; color:#64748b;"></h4>
                </div>
            </div>
            <div id="app"></div>
        </div>
    </div>
</div>

<script>
const DAYS = ["MONDAY","TUESDAY","WEDNESDAY","THURSDAY","FRIDAY"];
let DATA = [], REGISTRY = [], CLASSES = [], TEACHERS = [], SLOTS = [], currentView = 'GENERAL', logoBase64 = "";

function handleLogo(e) {
    const reader = new FileReader();
    reader.onload = (ev) => {
        logoBase64 = ev.target.result;
        const img = document.getElementById('logoImg');
        img.src = logoBase64; img.style.display = 'block';
    };
    reader.readAsDataURL(e.target.files[0]);
}

function handleCSV(e) {
    const reader = new FileReader();
    reader.onload = (ev) => {
        const lines = ev.target.result.split(/\r?\n/).filter(l => l.trim() !== "");
        const rawMap = {};
        lines.slice(1).forEach(line => {
            const cols = line.split(',').map(c => c.trim().toUpperCase());
            if (cols.length >= 4) {
                const key = `${cols[0]}|${cols[1]}|${cols[3]}`; // Sub | Tea | Class
                rawMap[key] = (rawMap[key] || 0) + 1;
            }
        });
        REGISTRY = []; CLASSES = []; TEACHERS = [];
        for (let k in rawMap) {
            const [sub, tea, frm] = k.split('|');
            REGISTRY.push({ sub, tea, frm, pwk: rawMap[k] });
            if(!CLASSES.includes(frm)) CLASSES.push(frm);
            if(!TEACHERS.includes(tea)) TEACHERS.push(tea);
        }
        alert("Success: Imported " + REGISTRY.length + " Allocations.");
        setView('GENERAL');
    };
    reader.readAsText(e.target.files[0]);
}

function buildSlots() {
    SLOTS = [];
    let cur = new Date("2026-01-01T" + document.getElementById('startTime').value);
    const totalP = parseInt(document.getElementById('totalPeriods').value);
    const dur = parseInt(document.getElementById('dur').value);
    const bAft = parseInt(document.getElementById('breakAfter').value);
    const lAft = parseInt(document.getElementById('lunchAfter').value);

    for(let i=1; i<=totalP; i++) {
        let sTime = cur.toTimeString().slice(0,5);
        cur.setMinutes(cur.getMinutes() + dur);
        SLOTS.push({ id: 'P'+i, time: `${sTime}-${cur.toTimeString().slice(0,5)}`, type: 'period' });
        
        if(i === bAft) {
            let bt = cur.toTimeString().slice(0,5); 
            cur.setMinutes(cur.getMinutes() + parseInt(document.getElementById('breakDur').value));
            SLOTS.push({ id: 'BREAK', time: `${bt}-${cur.toTimeString().slice(0,5)}`, type: 'break' });
        }
        if(i === lAft) {
            let lt = cur.toTimeString().slice(0,5); 
            cur.setMinutes(cur.getMinutes() + parseInt(document.getElementById('lunchDur').value));
            SLOTS.push({ id: 'LUNCH', time: `${lt}-${cur.toTimeString().slice(0,5)}`, type: 'lunch' });
        }
    }
}

function generate() {
    if(REGISTRY.length === 0) return alert("Please import a CSV first!");
    DATA = []; buildSlots();
    
    let pool = [...REGISTRY].sort((a,b) => b.pwk - a.pwk);
    
    pool.forEach(r => {
        let left = r.pwk;
        // 1. Prioritize One Double Period per subject per week
        for(let d of DAYS) {
            if(left < 2) break;
            for(let i=0; i<SLOTS.length-1; i++) {
                let s1 = SLOTS[i], s2 = SLOTS[i+1];
                if(s1.type==='period' && s2.type==='period' && !isBusy(d, s1.id, r) && !isBusy(d, s2.id, r)) {
                    DATA.push({...r, d, p: s1.id}, {...r, d, p: s2.id});
                    left -= 2; break; 
                }
            }
            if(r.pwk - left >= 2) break; // Ensure only one double is made per subject
        }

        // 2. Remaining Singles
        for(let d of DAYS) {
            if(left <= 0) break;
            for(let s of SLOTS.filter(x => x.type==='period')) {
                if(!isBusy(d, s.id, r)) {
                    DATA.push({...r, d, p: s.id});
                    left--; break;
                }
            }
        }
    });
    renderActiveView();
}

function isBusy(d,p,r){ return DATA.some(x=>x.d===d && x.p===p && (x.tea===r.tea || x.frm===r.frm)); }

function setView(v) {
    currentView = v;
    document.querySelectorAll('.tab-group button').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-'+v).classList.add('active');
    const fil = document.getElementById('viewFilter');
    const wa = document.getElementById('waBtn');
    
    fil.style.display = (v==='STREAM'||v==='TEACHER') ? 'inline-block' : 'none';
    wa.style.display = (v==='TEACHER') ? 'inline-block' : 'none';

    if(v==='STREAM') fil.innerHTML = CLASSES.map(c => `<option value="${c}">${c}</option>`).join('');
    if(v==='TEACHER') fil.innerHTML = TEACHERS.map(t => `<option value="${t}">${t}</option>`).join('');
    renderActiveView();
}

function renderActiveView() {
    document.getElementById('headerTitle').innerText = document.getElementById('schName').value;
    document.getElementById('headerYear').innerText = "ACADEMIC YEAR: " + document.getElementById('acadYear').value;
    const app = document.getElementById('app');
    
    if(currentView==='GENERAL') {
        let h = "";
        DAYS.forEach(day => {
            h += `<div class="table-card"><h3>${day}</h3><table><tr><th>Class</th>`;
            SLOTS.forEach(s => h += `<th>${s.id}<br><small>${s.time}</small></th>`);
            h += `</tr>`;
            CLASSES.forEach(f => {
                h += `<tr><td><b>${f}</b></td>`;
                SLOTS.forEach(s => {
                    if(s.type !== 'period') h += `<td class="break-cell">${s.id}</td>`;
                    else {
                        let m = DATA.find(x => x.d===day && x.p===s.id && x.frm===f);
                        h += `<td>${m ? `<div class="slot">${m.sub}<br>${m.tea}</div>`:''}</td>`;
                    }
                });
                h += `</tr>`;
            });
            h += `</table></div>`;
        });
        app.innerHTML = h;
    } else if(currentView==='STREAM'||currentView==='TEACHER') {
        const val = document.getElementById('viewFilter').value;
        if(!val) return app.innerHTML = "Select a filter to view.";
        const key = currentView === 'STREAM' ? 'frm' : 'tea';
        let h = `<div class="table-card"><h3>${val} Schedule</h3><table><tr><th>Day</th>`;
        SLOTS.forEach(s => h += `<th>${s.id}<br><small>${s.time}</small></th>`);
        h += `</tr>`;
        DAYS.forEach(d => {
            h += `<tr><td><b>${d}</b></td>`;
            SLOTS.forEach(s => {
                if(s.type !== 'period') h += `<td class="break-cell">${s.id}</td>`;
                else {
                    let m = DATA.find(x => x.d===d && x.p===s.id && x[key]===val);
                    h += `<td>${m ? `<div class="slot">${currentView==='STREAM'?m.sub+'<br>'+m.tea:m.sub+'<br>'+m.frm}</div>`:''}</td>`;
                }
            });
            h += `</tr>`;
        });
        app.innerHTML = h + `</table></div>`;
    } else if(currentView==='LOADS') {
        let h = `<div class="table-card"><h3>Teacher Workload Summary</h3><table><tr><th>Teacher</th><th>Periods / Week</th><th>Status</th></tr>`;
        TEACHERS.sort().forEach(t => {
            let c = DATA.filter(x => x.tea === t).length;
            h += `<tr><td>${t}</td><td>${c}</td><td>${c > 28 ? '<b style="color:red">OVERLOAD</b>' : 'NORMAL'}</td></tr>`;
        });
        app.innerHTML = h + `</table></div>`;
    }
}

function shareWA() {
    const teacher = document.getElementById('viewFilter').value;
    const msg = `*${document.getElementById('schName').value}*\n\nHello ${teacher},\nAttached is your official timetable for ${document.getElementById('acadYear').value}.`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
}

function exportPDF() {
    const opt = { margin: 5, filename: 'Master_Timetable.pdf', jsPDF: { orientation: 'landscape' } };
    html2pdf().from(document.getElementById('printableArea')).set(opt).save();
}
</script>
</body>
</html>
